PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret

# Gmail SMTP sender account
SMTP_USER=your_sender_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Admin inbox. If only username is given (e.g., ritikvarun64),
# the app auto-expands it to ritikvarun64@gmail.com.
ADMIN_EMAIL=admin_email_or_username
